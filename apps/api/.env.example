# ============================================================
# Kyoiru API - 環境変数テンプレート
# .env にコピーして実際の値を設定してください
# このファイル自体はコミットして構いません（秘密値は含めない）
# ============================================================

# --- サーバー設定 ---
PORT=3000
NODE_ENV=development
FRIENDS_SEARCH_RATE_LIMIT_MAX=20
FRIENDS_SEARCH_RATE_LIMIT_WINDOW_SECONDS=60
REVENUECAT_MONITORING_ENTITLEMENT_KEY=monitoring_plan
REVENUECAT_MONITORING_PLAN_NAME=見守りプラン
REVENUECAT_WEBHOOK_AUTH_HEADER=replace-with-secure-webhook-token
# RevenueCat app_user_id には公開 userId を使わず、
# 必ず `uuid:<users.id>` を送る

# --- データベース ---
DATABASE_URL=postgresql://user:password@localhost:5432/kyoiru_dev

# --- JWT (Access Token) ---
# 本番では openssl rand -hex 64 などで生成してください
JWT_ACCESS_SECRET=replace-with-secure-random-secret
JWT_ACCESS_EXPIRES_IN=15m

# --- Apple Sign In ---
# iOS アプリの Bundle ID (例: com.example.kyoiru)
# 取得先: Apple Developer Console > Identifiers
APPLE_CLIENT_ID=com.example.kyoiru

# --- Google Sign In ---
# iOS / Android 共通の OAuth 2.0 クライアント ID
# 取得先: Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# --- LINE ログイン ---
# LINE Login channel の channel ID
# 用途: LINE verify endpoint のレスポンス client_id と照合し、
#       Kyoiru の channel 向けに発行された token かどうかを確認する (audience 相当)
# 取得先: LINE Developers Console > Providers > Channel > Channel ID
LINE_CHANNEL_ID=1234567890

# --- 公開法務ページ ---
LEGAL_PRIVACY_POLICY_URL=https://example.com/privacy
LEGAL_TERMS_OF_SERVICE_URL=https://example.com/terms
LEGAL_COMMERCE_DISCLOSURE_URL=https://example.com/legal/commercial-transactions
LEGAL_SUPPORT_URL=https://example.com/support
