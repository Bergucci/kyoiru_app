  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.3",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "~5.9.2"
  }
