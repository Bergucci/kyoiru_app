{
  "name": "@kyoiru/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "lint": "eslint app src",
    "typecheck": "tsc --noEmit",
    "verify:step9": "node ./test/step9-mobile-connection.cjs",
    "build:brand": "node scripts/build-brand-assets.mjs && node scripts/build-brand-lottie.mjs"
  },
  "dependencies": {
    "@kyoiru/contracts": "workspace:*",
    "@kyoiru/domain": "workspace:*",
    "@xmartlabs/react-native-line": "^6.0.0",
    "expo": "~54.0.10",
    "expo-apple-authentication": "~8.0.7",
    "expo-auth-session": "~7.0.8",
    "expo-build-properties": "~0.14.0",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.7",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.7",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.8",
    "lottie-react-native": "~7.3.6",
    "moti": "^0.30.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1"
