# ============================================================
# Kyoiru Mobile - 環境変数テンプレート
# Expo では EXPO_PUBLIC_ プレフィックスが公開変数
# .env にコピーして実際の値を設定してください
# ============================================================

# --- API エンドポイント ---
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- アプリ設定 ---
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://example.com/privacy
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://example.com/terms
EXPO_PUBLIC_COMMERCE_DISCLOSURE_URL=https://example.com/legal/commercial-transactions
EXPO_PUBLIC_SUPPORT_URL=https://example.com/support

# --- ソーシャルログイン ---
# Google OAuth クライアント ID (Google Cloud Console で発行)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=

# LINE Login チャネル ID (LINE Developers Console で発行)
EXPO_PUBLIC_LINE_CHANNEL_ID=

# --- 外部サービス (Step 4以降で追加予定) ---
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
