{
  "expo": {
    "name": "Kyoiru",
    "slug": "kyoiru",
    "version": "1.0.0",
    "scheme": "kyoiru",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kyoiru.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kyoiru.app"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      ["expo-build-properties", { "ios": { "useFrameworks": "static" } }],
      "@xmartlabs/react-native-line",
      [
        "expo-image-picker",
        {
          "photosPermission": "プロフィールアイコンを設定するために写真ライブラリへのアクセスが必要です。"
        }
      ],
      "./plugins/with-line-sdk"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
